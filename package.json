{
  "name": "autotester",
  "version": "0.1.0",
  "description": "Program-driven coding-agent loops for conservative repository improvement",
  "type": "module",
  "bin": {
    "autotester": "./dist/cli.js"
  },
  "files": [
    "dist",
    "programs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "vitest --run",
    "check": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "packageManager": "pnpm@10.25.0",
  "keywords": [
    "agent",
    "coding-agent",
    "program",
    "automation",
    "testing"
  ],
  "author": "Ian Philpot",
  "license": "MIT"
}
